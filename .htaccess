# ─── HTTPS afdwingen ─────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ─── Korte link voor SCT: /s/<id> → /sct/v.php?id=<id> ───────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^s/([a-zA-Z0-9]{24})/?$ sct/v.php?id=$1 [L,QSA]
</IfModule>

# ─── Directory listings uitschakelen ─────────────────────────────────────────
Options -Indexes

# ─── Blokkeer directe toegang tot includes map ───────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^includes/ - [F,L]
</IfModule>

# ─── Blokkeer gevoelige bestanden (altijd, ook op productie) ──────────────────
<FilesMatch "^(migrate|migrate2|migrate3|migrate4|setup_key)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# migrate13 tijdelijk toegankelijk
<FilesMatch "^migrate13\.php$">
    Order allow,deny
    Allow from all
</FilesMatch>

# migrate_intranet tijdelijk toegankelijk
<FilesMatch "^migrate_intranet\.php$">
    Order allow,deny
    Allow from all
</FilesMatch>

# migrate_sct_label tijdelijk toegankelijk
<FilesMatch "^migrate_sct_label\.php$">
    Order allow,deny
    Allow from all
</FilesMatch>


# ─── Security headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Klik-jacking voorkomen
    Header always set X-Frame-Options "DENY"

    # Voorkomt MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # HTTPS verplichten voor 2 jaar (alleen activeren als HTTPS 100% werkt!)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"

    # Beperkt welke info de browser doorstuurt bij links
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Schakel onnodige browser-features uit
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(self), payment=()"

    # Content Security Policy
    # Staat CDN (Bootstrap, Remix Icons) en inline scripts toe — pas aan als nodig
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' https://cdn.jsdelivr.net 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'none'"
</IfModule>

# ─── Verberg PHP-versie ───────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header unset X-Powered-By
</IfModule>
